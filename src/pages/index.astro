---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";
import SocialIcon from "@components/SocialIcon.astro";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section class="animate flex flex-col-reverse gap-8 sm:flex-row sm:items-start sm:justify-between">
        <article class="max-w-md space-y-4">
          <h4 class="font-semibold text-black dark:text-white">
            Hi, I'm Shubham <span class="text-xl">👋🏻</span>
          </h4>
          <p>
            Full Stack developer who loves building end-to-end real-world
            solutions. Comfortable working with any technology or tool required
            to solve a problem.
          </p>
          <p>
            Building SaaS products, backend systems, and practical tools.
            <span class="float-right text-black/50 dark:text-white/75">
              <Link href="/about"> Read more </Link>
            </span>
          </p>
        </article>
        <img
          src="/profile_photos/shubham_profile.png"
          alt="Shubham Atkal"
          width="112"
          height="112"
          class="size-24 shrink-0 rounded-full object-cover ring-1 ring-black/10 dark:ring-white/15 sm:size-28"
        />
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
          <Link href="/work"> See all work </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {
            work.map((entry) => (
              <li>
                <div class="text-sm opacity-75">
                  {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm opacity-75">{entry.data.role}</div>
                <article>
                  <entry.Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects"> See all projects </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">Let's Connect</h5>
        <article>
          <p>
            You can connect with me on LinkedIn or github or send me an email —
            I'd be happy to hear from you!
          </p>
        </article>
        <ul class="flex flex-wrap [&>li:first-child_a]:pl-0">
          {
            SOCIALS.map((SOCIAL) => (
              <li>
                <SocialIcon
                  icon={SOCIAL.ICON}
                  href={SOCIAL.HREF}
                  name={SOCIAL.NAME}
                  ariaLabel={`${SITE.NAME} on ${SOCIAL.NAME}`}
                />
              </li>
            ))
          }
        </ul>
        <div class="mt-4">
          <a
            href={`mailto:${SITE.EMAIL}`}
            aria-label={`Email ${SITE.NAME}`}
            class="text-gray-600 hover:text-black hover:dark:text-white transition-colors duration-300 ease-in-out"
          >
            {SITE.EMAIL}
          </a>
        </div>
      </section>
    </div>
  </Container>
</PageLayout>
